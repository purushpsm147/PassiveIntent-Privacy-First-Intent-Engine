{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "stripInternal": true,
    "tsBuildInfoFile": "dist/tsconfig.types.tsbuildinfo"
  },
  "include": ["src/**/*.ts"]
}
